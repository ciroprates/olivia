# Pluggy API credentials
PLUGGY_CLIENT_ID=your-pluggy-client-id
PLUGGY_CLIENT_SECRET=your-pluggy-client-secret

# Default banks (used when payload.banks is not sent)
# Comma-separated Pluggy item IDs
# Example: BANKS=uuid-1,uuid-2,uuid-3
BANKS=

# Optional execution defaults
# OPTIONS_START_DATE=2026-01-01
# OPTIONS_EXCLUDE_CATEGORIES=Same person transfer,Credit card payment
OPTIONS_START_DATE=
OPTIONS_EXCLUDE_CATEGORIES=

# Sheet defaults
# If SHEET_SPREADSHEET_ID is empty, GOOGLE_SPREADSHEET_ID is used
SHEET_ENABLED=true
SHEET_SPREADSHEET_ID=
SHEET_TAB_NAME=Homologação

# Artifacts defaults
ARTIFACTS_CSV_ENABLED=false

# Google Sheets Integration (Optional)
# If you want to automatically update a Google Sheet with transaction data:
# 1. Create a Google Cloud Service Account
# 2. Download the JSON key file
# 3. Share your Google Sheet with the service account email (found in the JSON file)
# 4. Set the path to the JSON key file below
# 5. Set your spreadsheet ID (found in the spreadsheet URL)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account-key.json
GOOGLE_SPREADSHEET_ID=your-spreadsheet-id-here
